# Central Intelligence — backend environment template.
# Copy to `.env` for local dev; on Render set these in the dashboard (the
# render.yaml marks them `sync: false`). NEVER commit real values — `.env` is
# gitignored; this `.env.example` is the only env file that is tracked.

# --- Runtime ---
DEBUG=false
# Staging can start in mock mode (no paid API calls). Flip to false to go live.
MOCK_MODE=true

# --- Datastores / auth (Supabase) ---
# App DB — migrate/write freely. Use the asyncpg driver scheme and URL-encode
# any special chars in the password.
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@db.<ref>.supabase.co:5432/postgres
# CI's OWN Supabase — drives user login / auth. Matches DATABASE_URL's project.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# --- Redis (Celery broker + backend) ---
# On Render this is injected from the managed ci-redis service. Locally:
REDIS_URL=redis://localhost:6379/0

# --- AI providers (required only when MOCK_MODE=false) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-proj-...
VOYAGE_API_KEY=pa-...

# --- CORS / public URL ---
# Parsed as a JSON list by pydantic-settings — use a JSON array.
CORS_ORIGINS=["http://localhost:3000"]
PUBLIC_API_BASE_URL=http://localhost:8000

# --- Integrations (optional; blank falls back to seed data) ---
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATIONS_ENCRYPTION_KEY=
MAILCHIMP_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/integrations/google_workspace/oauth/callback

# --- Client WGR mirror (READ-ONLY data source; keep OFF in staging) ---
CLIENT_SYNC_ENABLED=false
CLIENT_SUPABASE_URL=
CLIENT_SUPABASE_ANON_KEY=
# SAFETY: WGR_DATABASE_URL is the client's `postgres` role and CAN WRITE.
# Every connection MUST be opened READ ONLY. Leave blank unless syncing.
WGR_DATABASE_URL=
