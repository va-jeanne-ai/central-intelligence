# Central Intelligence — frontend environment template.
# Copy to `.env.local` for local dev; on Render set these on the ci-frontend
# service. NOTE: NEXT_PUBLIC_* vars are baked in at BUILD time — changing them
# requires a rebuild, not just a restart.
#
# Leave the SUPABASE vars empty to run auth in mock mode (no credentials needed).

# Backend API base (include the /api/v1 suffix).
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# WebSocket base for live updates (ws:// locally, wss:// in production).
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/v1

# Supabase auth (must match the backend's SUPABASE_URL / SUPABASE_ANON_KEY).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
